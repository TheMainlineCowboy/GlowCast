# GlowCast high-precision CV backend providers
# Add matching values in Cloudflare Pages > Settings > Environment variables.

# Geometry / homography provider
# Use a hosted MLSD/ControlNet endpoint or custom OpenCV Hough Transform service.
GEOMETRY_API_URL=
GEOMETRY_API_KEY=

# SAM 2 segmentation provider
# Must return polygon masks, SVG paths, or binary/alpha masks for architectural openings.
SAM2_API_URL=
SAM2_API_KEY=

# Depth provider
# Use Depth Anything V2, MiDaS, or a compatible monocular-depth API endpoint.
DEPTH_API_URL=
DEPTH_API_KEY=
